generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= USER MANAGEMENT =============
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  avatar        String?
  bio           String?
  role          UserRole  @default(USER)
  emailVerified Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  // Relations
  reviews         Review[]
  ratings         Rating[]
  readingLists    ReadingList[]
  favorites       Favorite[]
  readingProgress ReadingProgress[]
  annotations     Annotation[]
  comments        Comment[]

  @@index([email])
  @@index([username])
  @@map("users")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

// ============= CORE ENTITIES =============
model Author {
  id          String   @id @default(cuid())
  name        String
  nameEn      String?
  bio         String?
  birthDate   DateTime?
  deathDate   DateTime?
  nationality String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  books Book[]

  @@index([name])
  @@map("authors")
}

model Book {
  id              String       @id @default(cuid())
  title           String
  titleEn         String?
  originalTitle   String?
  isbn            String?      @unique
  publicationYear Int?
  publisher       String?
  language        String       @default("fa")
  pageCount       Int?
  description     String?
  coverImage      String?
  status          BookStatus   @default(DRAFT)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  authorId     String
  author       Author            @relation(fields: [authorId], references: [id])
  categories   BookCategory[]
  translations Translation[]
  reviews      Review[]
  ratings      Rating[]
  favorites    Favorite[]
  readingLists ReadingListItem[]
  readingProgress ReadingProgress[]
  annotations  Annotation[]

  @@index([authorId])
  @@index([isbn])
  @@index([title])
  @@map("books")
}

enum BookStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  nameEn      String?
  slug        String   @unique
  description String?
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  parent   Category?      @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[]     @relation("CategoryHierarchy")
  books    BookCategory[]

  @@index([slug])
  @@map("categories")
}

model BookCategory {
  bookId     String
  categoryId String
  createdAt  DateTime @default(now())

  // Relations
  book     Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([bookId, categoryId])
  @@map("book_categories")
}

// ============= TRANSLATIONS =============
model Translation {
  id            String           @id @default(cuid())
  bookId        String
  translatorId  String
  title         String
  publicationYear Int?
  publisher     String?
  isbn          String?          @unique
  language      String           @default("fa")
  quality       TranslationQuality @default(GOOD)
  status        TranslationStatus @default(PUBLISHED)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  book       Book       @relation(fields: [bookId], references: [id])
  translator Translator @relation(fields: [translatorId], references: [id])

  @@index([bookId])
  @@index([translatorId])
  @@map("translations")
}

enum TranslationQuality {
  EXCELLENT
  GOOD
  AVERAGE
  POOR
}

enum TranslationStatus {
  DRAFT
  PUBLISHED
  OUT_OF_PRINT
}

model Translator {
  id          String   @id @default(cuid())
  name        String
  nameEn      String?
  bio         String?
  birthDate   DateTime?
  nationality String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  translations Translation[]

  @@index([name])
  @@map("translators")
}

// ============= REVIEWS & RATINGS =============
model Review {
  id        String       @id @default(cuid())
  bookId    String
  userId    String
  title     String?
  content   String
  rating    Float        @default(0)
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relations
  book     Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([bookId])
  @@index([userId])
  @@index([status])
  @@map("reviews")
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

model Rating {
  id        String   @id @default(cuid())
  bookId    String
  userId    String
  score     Float    // 1-5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bookId, userId])
  @@index([bookId])
  @@map("ratings")
}

model Comment {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("comments")
}

// ============= USER INTERACTIONS =============
model ReadingList {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ReadingListItem[]

  @@index([userId])
  @@map("reading_lists")
}

model ReadingListItem {
  id            String   @id @default(cuid())
  readingListId String
  bookId        String
  order         Int      @default(0)
  createdAt     DateTime @default(now())

  // Relations
  readingList ReadingList @relation(fields: [readingListId], references: [id], onDelete: Cascade)
  book        Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([readingListId, bookId])
  @@index([readingListId])
  @@map("reading_list_items")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@map("favorites")
}

model ReadingProgress {
  id             String         @id @default(cuid())
  userId         String
  bookId         String
  currentPage    Int            @default(0)
  totalPages     Int
  status         ReadingStatus  @default(TO_READ)
  startedAt      DateTime?
  completedAt    DateTime?
  lastReadAt     DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@map("reading_progress")
}

enum ReadingStatus {
  TO_READ
  READING
  COMPLETED
  ABANDONED
}

model Annotation {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  page      Int
  content   String
  highlight String?
  color     String?  @default("#FFFF00")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([bookId])
  @@map("annotations")
}
