# =====================
# Auth Service Environment
# =====================

# Server
PORT=4000
HOST=0.0.0.0
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://bibliograph:bibliograph_dev_2024@localhost:5435/bibliograph_db?schema=public"

# JWT / Auth
JWT_SECRET="your_jwt_secret_here_change_in_production"
JWT_EXPIRES_IN="1d"
REFRESH_TOKEN_EXPIRES_IN="7d"

# OAuth (Google)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:4000/auth/google/callback"

# Email
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASS="your_smtp_password"
EMAIL_FROM="noreply@bibliograph.ir"

# Redis (Cache & Session)
REDIS_URL="redis://:bibliograph_dev_2024@localhost:6379"
REDIS_DB=0

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# CORS
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"
CORS_ALLOWED_METHODS="GET,POST,PUT,DELETE,OPTIONS"
CORS_ALLOWED_HEADERS="Content-Type,Authorization"

# File Storage (MinIO/S3)
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="bibliograph"
MINIO_SECRET_KEY="bibliograph_dev_2024"
MINIO_BUCKET="bibliograph-files"
MINIO_USE_SSL=false

# Logging
LOG_LEVEL="info"
LOG_FORMAT="json"